generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Unit {
  id            String          @id @default(cuid())
  name          String
  type          String
  address       String?
  phone         String?
  adminName     String?
  doctors       Doctor[]
  receptionists Receptionist[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Specialty {
  id        String              @id @default(cuid())
  name      String              @unique
  doctors   Doctor[]
  templates SpecialtyTemplate[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model Doctor {
  id              String      @id @default(cuid())
  name            String
  email           String?
  unitId          String
  specialtyId     String?
  phone           String?
  licenseNumber   String?
  canEditPatients Boolean     @default(true)
  canManageVisits Boolean     @default(true)
  unit            Unit        @relation(fields: [unitId], references: [id])
  specialty       Specialty?  @relation(fields: [specialtyId], references: [id])
  patients        Patient[]
  appointments    Appointment[]
  visits          VisitEntry[]
  schedules       DoctorSchedule[]
  blockedTimes    DoctorBlockedTime[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model DoctorSchedule {
  id        String   @id @default(cuid())
  doctorId  String
  dayOfWeek Int
  startTime String
  endTime   String
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DoctorBlockedTime {
  id             String   @id @default(cuid())
  doctorId       String
  start          DateTime
  end            DateTime
  reason         String?
  recurrenceType String   @default("date")
  dayOfWeek      Int?
  startTime      String?
  endTime        String?
  doctor         Doctor   @relation(fields: [doctorId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Receptionist {
  id        String   @id @default(cuid())
  name      String
  email     String?
  address   String
  phone     String
  unitId    String
  unit      Unit     @relation(fields: [unitId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Patient {
  id           String        @id @default(cuid())
  doctorId     String
  name         String
  phone        String?
  address      String?
  historyDate  String?
  doctor       Doctor        @relation(fields: [doctorId], references: [id])
  appointments Appointment[]
  visits       VisitEntry[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Appointment {
  id                 String   @id @default(cuid())
  doctorId           String
  patientId          String
  title              String
  start              DateTime
  end                DateTime
  status             String   @default("scheduled")
  attended           Boolean  @default(false)
  notes              String?
  paymentType        String?
  cancellationReason String?
  cancelledAt        DateTime?
  doctor             Doctor   @relation(fields: [doctorId], references: [id])
  patient            Patient  @relation(fields: [patientId], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model SpecialtyTemplate {
  id          String           @id @default(cuid())
  specialtyId String
  specialty   Specialty        @relation(fields: [specialtyId], references: [id])
  fields      SpecialtyField[]
  visits      VisitEntry[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model SpecialtyField {
  id         String            @id @default(cuid())
  templateId String
  label      String
  type       String
  required   Boolean           @default(false)
  template   SpecialtyTemplate @relation(fields: [templateId], references: [id])
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model VisitEntry {
  id         String            @id @default(cuid())
  doctorId   String
  patientId  String
  templateId String
  date       DateTime
  responses  Json
  doctor     Doctor            @relation(fields: [doctorId], references: [id])
  patient    Patient           @relation(fields: [patientId], references: [id])
  template   SpecialtyTemplate @relation(fields: [templateId], references: [id])
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String
  doctorId  String?
  receptionistId String?
  unitId    String?
  mustChangePassword Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppSettings {
  id           String   @id @default("default")
  startHour    Int      @default(8)
  endHour      Int      @default(20)
  slotMinutes  Int      @default(30)
  allowOverlap Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id             String   @id @default(cuid())
  userId         String?
  role           String?
  unitId         String?
  doctorId       String?
  receptionistId String?
  action         String
  entityType     String
  entityId       String?
  summary        String?
  before         Json?
  after          Json?
  createdAt      DateTime @default(now())
}
